@using Microsoft.AspNetCore.Mvc.TagHelpers
@model Category

<link rel="stylesheet" href="~/css/Category/create.css">


<form asp-action="Create" asp-controller="Category" method="post" enctype="multipart/form-data">
    <div class="border p-3 mt4">
        <div class="row pb-2">
            <h2 class="text-Dark">Create Category</h2>
            <hr>
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="mb-3">
                <label asp-for="Name" class="form-label p-0 mb-1"></label>
                <input class="form-control" asp-for="Name" name="name" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="DisplayOrder" class="p-0 mb-1 form-label"></label>
                <input asp-for="DisplayOrder" class="form-control" name="DisplayOrder" />
                <span asp-validation-for="DisplayOrder" class="text-danger"></span>
            </div>
        </div>
        <div class="row ">
            <div class="col-6 col-md-3">
                <input type="submit" class="btn btn-primary form-control" />
            </div>
            <div class="col-6 col-md-3">
                <a class="btn btn-outline-danger form-control" asp-controller="Category" asp-action="Index">Cancel</a>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    <partial action="_ValidationScriptsPartial" />
}