@model Category
@{
    ViewData["Title"] = "Edit";
}

<form asp-action="Edit" asp-controller="Category" method="post" enctype="multipart/form-data">
    <div class="border p-3 mt4">
        <div class="row pb-2">
            <h2 class="text-Dark">Edit Category</h2>
            <hr>
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="mb-3">
                <label asp-for="Name" class="form-label p-0 mb-1"></label>
                <input class="form-control" asp-for="Name" name="name" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Description" class="p-0 mb-1 form-label"></label>
                <input asp-for="Description" class="form-control" name="Description" />
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>
        </div>
        <div class="row ">
            <div class="col-6 col-md-3">
                <input type="submit" class="btn btn-primary form-control" />
            </div>
            <div class="col-6 col-md-3">
                <a class="btn btn-outline-danger form-control" asp-controller="Category" asp-action="Index">Cancel</a>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    @* <partial action="_ValidationScriptsPartial" /> *@
}