@{
    ViewData["Title"] = "Create Product";
}
@model CreateProductVM

<style>
    .validation-summary-valid {
        display: none !important;
    }

    .create-card {
        border: none;
        border-radius: 16px;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.12);
        overflow: hidden;
    }

    .create-card .card-header {
        background: linear-gradient(135deg, #1a1a1a 0%, #2d2d2d 100%);
        border-bottom: none;
        padding: 1.75rem 2rem;
    }

    .create-card .card-body {
        padding: 2rem;
        background: #fff;
    }

    .form-label {
        font-weight: 600;
        font-size: 0.875rem;
        color: #374151;
        margin-bottom: 0.4rem;
    }

    .form-control,
    .form-select {
        border-radius: 10px;
        border: 1.5px solid #e5e7eb;
        padding: 0.6rem 0.9rem;
        font-size: 0.95rem;
        transition: border-color 0.2s, box-shadow 0.2s;
    }

    .form-control:focus,
    .form-select:focus {
        border-color: #2563eb;
        box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.12);
    }

    .form-control.is-invalid,
    .form-select.is-invalid {
        border-color: #dc3545;
        box-shadow: none;
    }

    .form-control.is-invalid:focus,
    .form-select.is-invalid:focus {
        box-shadow: 0 0 0 3px rgba(220, 53, 69, 0.12);
    }

    /* Multi-select categories */
    #CategoryIds {
        min-height: 150px;
        border-radius: 10px;
    }

    #CategoryIds option {
        padding: 0.45rem 0.75rem;
        cursor: pointer;
        transition: background-color 0.15s;
    }

    #CategoryIds option:checked {
        background-color: #2563eb;
        color: #fff;
    }

    .category-hint {
        font-size: 0.8rem;
        color: #6b7280;
        margin-top: 0.35rem;
    }

    /* Input group for price / discount */
    .input-group-text {
        border-radius: 10px 0 0 10px;
        border: 1.5px solid #e5e7eb;
        background-color: #f9fafb;
        color: #6b7280;
        font-weight: 600;
    }

    .input-group .form-control {
        border-radius: 0 10px 10px 0;
    }

    .input-group:focus-within .input-group-text {
        border-color: #2563eb;
    }

    .input-group .form-control.is-invalid {
        border-left-color: #e5e7eb;
    }

    /* Buttons */
    #btn-create {
        @* background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 100%); *@ border: none;
        border-radius: 10px;
        padding: 0.65rem 2rem;
        font-weight: 600;
        letter-spacing: 0.02em;
        transition: transform 0.15s, box-shadow 0.15s;
    }

    #btn-create:hover {
        transform: translateY(-1px);
        box-shadow: 0 6px 20px rgba(37, 99, 235, 0.35);
    }

    #btn-cancel {
        border-radius: 10px;
        padding: 0.65rem 1.5rem;
        font-weight: 600;
        border: 1.5px solid #d1d5db;
        color: #374151;
        transition: background-color 0.15s, border-color 0.15s;
    }

    #btn-cancel:hover {
        background-color: #f3f4f6;
        border-color: #9ca3af;
    }

    .section-divider {
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: #9ca3af;
        border-bottom: 1px solid #f3f4f6;
        padding-bottom: 0.4rem;
        margin-bottom: 1.25rem;
    }
</style>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-1">
                <li class="breadcrumb-item">
                    <a asp-area="User" asp-controller="Product" asp-action="Index" class="text-decoration-none">Products</a>
                </li>
                <li class="breadcrumb-item active" aria-current="page">Create</li>
            </ol>
        </nav>
        <h2 class="mb-0 fw-bold">New Product</h2>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-lg-8 col-xl-7">
        <div class="card create-card">
            <div class="card-header">
                <div class="d-flex align-items-center gap-3">
                    <div class="bg-white bg-opacity-10 rounded-circle p-2">
                        <i class="bi bi-box-seam text-white fs-4"></i>
                    </div>
                    <div>
                        <h5 class="text-white mb-0 fw-bold">Product Details</h5>
                        <small class="text-white-50">Fill in the information below to create a new product</small>
                    </div>
                </div>
            </div>

            <div class="card-body">
                <form asp-area="User" asp-controller="Product" asp-action="Create" method="post" novalidate>
                    @Html.AntiForgeryToken()

                    @* Global validation summary *@
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 rounded-3"></div>

                    @* — Basic Info — *@
                    <p class="section-divider">
                        <i class="bi bi-info-circle me-1"></i> Basic Information
                    </p>

                    <div class="mb-3">
                        <label asp-for="Product.Name" class="form-label">
                            <i class="bi bi-tag me-1 text-muted"></i> Product Name <span class="text-danger">*</span>
                        </label>
                        <input asp-for="Product.Name" id="Name" class="form-control" placeholder="e.g. Running Shoes Pro X" autocomplete="off"/>
                        <span asp-validation-for="Product.Name" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Product.Description" class="form-label">
                            <i class="bi bi-card-text me-1 text-muted"></i> Description
                        </label>
                        <textarea asp-for="Product.Description" id="Description" class="form-control" rows="3"
                                  placeholder="Write a short product description…" maxlength="1000"></textarea>
                        <div class="d-flex justify-content-between">
                            <span asp-validation-for="Product.Description" class="text-danger small"></span>
                            <small class="text-muted ms-auto" id="desc-counter">0 / 1000</small>
                        </div>
                    </div>

                    @* — Pricing — *@
                    <p class="section-divider mt-4">
                        <i class="bi bi-currency-dollar me-1"></i> Pricing
                    </p>

                    <div class="row g-3 mb-3">
                        <div class="col-sm-6">
                            <label asp-for="Product.Price" class="form-label">
                                Price <span class="text-danger">*</span>
                            </label>
                            <div class="input-group">
                                <span class="input-group-text">$</span>
                                <input asp-for="Product.Price" id="Price" type="number" step="0.01" min="0.01" max="999999.99"class="form-control" placeholder="0.00"/>
                            </div>
                            <span asp-validation-for="Product.Price" class="text-danger small"></span>
                        </div>

                        <div class="col-sm-6">
                            <label asp-for="Product.Discount" class="form-label">
                                Discount (%)
                            </label>
                            <div class="input-group">
                                <input asp-for="Product.Discount" id="Discount" type="number" step="0.01" min="0" max="100"
                                       class="form-control" placeholder="0"/>
                                <span class="input-group-text" style="border-radius:0 10px 10px 0; border-left:none;">%</span>
                            </div>
                            <span asp-validation-for="Product.Discount" class="text-danger small"></span>
                        </div>
                    </div>

                    @* — Classification — *@
                    <p class="section-divider mt-4">
                        <i class="bi bi-diagram-3 me-1"></i> Classification
                    </p>

                    <div class="mb-3">
                        <label asp-for="Product.BrandId" class="form-label">
                            <i class="bi bi-award me-1 text-muted"></i> Brand <span class="text-danger">*</span>
                        </label>
                        <select asp-for="Product.BrandId" id="BrandId" asp-items="Model.Brands" class="form-select">
                            <option value="" disabled selected>— Select a brand —</option>
                        </select>
                        <span asp-validation-for="Product.BrandId" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="CategoryIds" class="form-label">
                            <i class="bi bi-grid me-1 text-muted"></i> Categories <span class="text-danger">*</span>
                        </label>
                        <select asp-for="CategoryIds" asp-items="@Model.Categories" class="form-select" id="CategoryIds" multiple></select>
                    </div>
                    @* — Actions — *@
                    <div class="d-flex gap-2 justify-content-end pt-2 border-top">
                        <a id="btn-cancel" asp-area="User" asp-controller="Product" asp-action="Index" class="btn">
                            <i class="bi bi-x-circle me-1"></i> Cancel
                        </a>
                        <button id="btn-create" type="submit" class="btn btn-success">
                            <i class="bi bi-plus-circle me-1"></i> Create Product
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial"/>

    <script>
        // Description character counter
        const descArea = document.getElementById('Description');
        const counter = document.getElementById('desc-counter');
        if (descArea && counter) {
            const update = () => counter.textContent = `${descArea.value.length} / 1000`;
            descArea.addEventListener('input', update);
            update();
        }

        // Highlight the multi-select on focus/blur
        const categorySelect = document.getElementById('CategoryIds');
        if (categorySelect) {
            categorySelect.addEventListener('focus', () =>
                categorySelect.style.borderColor = '#2563eb');
            categorySelect.addEventListener('blur', () =>
                categorySelect.style.borderColor = '');
        }
    </script>
}
